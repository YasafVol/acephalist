---
import PageLayout from "@layouts/PageLayout.astro"
import TopLayout from "@layouts/TopLayout.astro"
import BottomLayout from "@layouts/BottomLayout.astro"
---

<PageLayout
  title="Shared Note"
  description="View a shared scratchpad note."
  robots="noindex,nofollow"
>
  <TopLayout>
    <div class="animate">
      <h1 class="text-3xl font-semibold text-black dark:text-white mt-2">
        Shared Note
      </h1>
      <div class="mt-1">
        This link opens an unlisted scratchpad note.
      </div>
    </div>
  </TopLayout>
  <BottomLayout>
    <div class="animate">
      <div
        id="share-status"
        class="text-sm uppercase text-black/60 dark:text-white/60"
      >
        Loading shared note...
      </div>
      <div class="mt-4">
        <h2
          id="share-title"
          class="text-xl font-semibold text-black dark:text-white"
        ></h2>
        <div
          id="share-body"
          class="mt-3 whitespace-pre-wrap text-black/80 dark:text-white/80"
        ></div>
      </div>
    </div>
  </BottomLayout>

  <script is:inline>
    const statusEl = document.getElementById("share-status")
    const titleEl = document.getElementById("share-title")
    const bodyEl = document.getElementById("share-body")

    function setStatus(text) {
      if (statusEl) statusEl.textContent = text
    }

    async function loadNote() {
      const params = new URLSearchParams(window.location.search)
      const token = params.get("share")

      if (!token) {
        setStatus("Missing share token.")
        return
      }

      try {
        const res = await fetch(`/api/notes-share?token=${encodeURIComponent(token)}`)
        if (!res.ok) {
          setStatus("Note not found or unavailable.")
          return
        }

        const note = await res.json()
        setStatus("Shared note")
        if (titleEl) titleEl.textContent = note.title || "Untitled"
        if (bodyEl) bodyEl.textContent = note.body || ""
      } catch (err) {
        setStatus("Failed to load note.")
      }
    }

    loadNote()
  </script>
</PageLayout>
