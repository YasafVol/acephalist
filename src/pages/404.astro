---
import PageLayout from "@layouts/PageLayout.astro"
import TopLayout from "@layouts/TopLayout.astro"
import BottomLayout from "@layouts/BottomLayout.astro"
---

<PageLayout title="Not Found" description="The requested page could not be found." robots="noindex,nofollow">
  <TopLayout>
    <section class="animate">
      <div class="text-sm font-semibold uppercase tracking-[0.24em] text-black/45 dark:text-white/45">
        404
      </div>
      <h1 class="mt-3 max-w-2xl text-4xl font-semibold tracking-tight text-black dark:text-white md:text-5xl">
        This page is no longer here.
      </h1>
      <p class="mt-4 max-w-2xl text-base leading-7 text-black/65 dark:text-white/65 md:text-lg">
        Some drafts, stubs, and old paths are intentionally hidden while the site is being cleaned up.
      </p>
    </section>
  </TopLayout>

  <BottomLayout>
    <section class="animate border-t border-black/10 py-8 dark:border-white/15">
      <div class="grid gap-3 sm:grid-cols-3">
        <a
          href="/"
          class="group border border-black/15 p-4 transition-colors duration-300 ease-in-out hover:bg-black/[0.03] dark:border-white/15 dark:hover:bg-white/[0.04]"
        >
          <div class="text-sm font-semibold text-black dark:text-white">
            Home
          </div>
          <div class="mt-2 text-sm leading-6 text-black/55 dark:text-white/55">
            Return to the main page.
          </div>
        </a>

        <a
          href="/blog"
          class="group border border-black/15 p-4 transition-colors duration-300 ease-in-out hover:bg-black/[0.03] dark:border-white/15 dark:hover:bg-white/[0.04]"
        >
          <div class="text-sm font-semibold text-black dark:text-white">
            Blog
          </div>
          <div class="mt-2 text-sm leading-6 text-black/55 dark:text-white/55">
            Read published writing.
          </div>
        </a>

        <a
          href="/search"
          class="group border border-black/15 p-4 transition-colors duration-300 ease-in-out hover:bg-black/[0.03] dark:border-white/15 dark:hover:bg-white/[0.04]"
        >
          <div class="text-sm font-semibold text-black dark:text-white">
            Search
          </div>
          <div class="mt-2 text-sm leading-6 text-black/55 dark:text-white/55">
            Find current pages.
          </div>
        </a>
      </div>
    </section>
  </BottomLayout>
</PageLayout>
