---
type Props = {
  text: string
  href: string
  icon?: string
  imageSrc?: string
  imageAlt?: string
  imageClass?: string
}

const { text, icon, href, imageSrc, imageAlt = "", imageClass = "" } = Astro.props
---

<a href={href} target="_blank" class="w-fit px-3 py-2 group rounded border flex gap-2 items-center border-neutral-200 dark:border-neutral-700 hover:bg-neutral-100 hover:dark:bg-neutral-800 blend">
  {
    icon ? (
      <svg height={20} width={20}>
        <use href={`/stack.svg#${icon}`}></use>
      </svg>
    ) : imageSrc ? (
      <img
        src={imageSrc}
        alt={imageAlt}
        width="20"
        height="20"
        class={`size-5 object-contain ${imageClass}`}
        loading="lazy"
        decoding="async"
      />
    ) : null
  }
  <span class="text-sm text-neutral-500 dark:text-neutral-400 group-hover:text-black group-hover:dark:text-white blend">
    {text}
  </span>
</a>
