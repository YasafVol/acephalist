</button>

<script is:inline>
  const HOME_ANIMATION_PANEL_STORAGE_KEY = "acephalist-home-animation-panel-collapsed";

  function readHomeAnimationPath(source, path) {
    return path.split(".").reduce((value, key) => value?.[key], source);
  }

  function getHomeAnimationTheme() {
    return document.documentElement.classList.contains("dark") ? "dark" : "light";
  }

  function formatHomeAnimationValue(input, value) {
    if (input.type === "checkbox") {
      return value ? "On" : "Off";
    }

    if (input.dataset.format === "percent") {
      return `${Math.round(Number(value) * 100)}%`;
    }

    if (input.dataset.unit) {
      return `${value}${input.dataset.unit}`;
    }

    return `${value}`;
  }

  function mountHomeAnimationPanel() {
    const panel = document.getElementById("home-animation-controls");
    const openButton = document.getElementById("home-animation-toggle");
    const store = window.__homeAnimation;

    if (!panel || !openButton || !store) {
      return () => {};
    }

    const inputs = [...panel.querySelectorAll("[data-path]")];
    const outputNodes = [...panel.querySelectorAll("[data-output-for]")];
    const themeScopedNodes = [...panel.querySelectorAll("[data-visible-in]")];
    const detailsSections = [...panel.querySelectorAll("details")];
    const enabledSections = [...panel.querySelectorAll("details[data-enabled-path]")];
    const globalColorsButton = panel.querySelector("[data-global-colors-button]");
    const enabledToggleButtons = [...panel.querySelectorAll("[data-enabled-toggle-path]")];

    const syncThemeVisibility = () => {
      const theme = getHomeAnimationTheme();

      themeScopedNodes.forEach((node) => {
        const visibleIn = node.dataset.visibleIn?.split(",").map((item) => item.trim()) ?? [];
        node.classList.toggle("hidden", !visibleIn.includes(theme));
      });
    };

    const setCollapsed = (collapsed) => {
      panel.classList.toggle("hidden", collapsed);
      openButton.classList.toggle("hidden", !collapsed);
      openButton.classList.toggle("flex", collapsed);

      try {
        window.localStorage.setItem(HOME_ANIMATION_PANEL_STORAGE_KEY, collapsed ? "1" : "0");
      } catch {}
    };

    const render = (config) => {
      inputs.forEach((input) => {
        const value = readHomeAnimationPath(config, input.dataset.path);

        if (input.type === "checkbox") {
          input.checked = Boolean(value);
        } else {
          input.value = `${value}`;
        }
      });

      outputNodes.forEach((outputNode) => {
        const path = outputNode.dataset.outputFor;
        const input = panel.querySelector(`[data-path="${path}"]`);
        const value = readHomeAnimationPath(config, path);

        if (!input) {
          return;
        }

        outputNode.textContent = formatHomeAnimationValue(input, value);
      });

      enabledToggleButtons.forEach((button) => {
        const enabled = Boolean(readHomeAnimationPath(config, button.dataset.enabledTogglePath));
        button.dataset.active = enabled ? "true" : "false";
        button.setAttribute("aria-pressed", enabled ? "true" : "false");
      });

      enabledSections.forEach((section) => {
        const enabled = Boolean(readHomeAnimationPath(config, section.dataset.enabledPath));
        const manualState = section.dataset.manualState;

        if (!enabled && manualState !== "open") {
          section.open = false;
        } else if (enabled && !manualState) {
          section.open = true;
        }
      });

      if (globalColorsButton instanceof HTMLButtonElement) {
        const colorsEnabled = Boolean(config.twinkle.randomColors && config.meteor.randomColors);
        globalColorsButton.dataset.active = colorsEnabled ? "true" : "false";
        globalColorsButton.setAttribute("aria-pressed", colorsEnabled ? "true" : "false");
        const paletteIcon = globalColorsButton.querySelector('[data-color-icon="palette"]');
        const yinYangIcon = globalColorsButton.querySelector('[data-color-icon="yinyang"]');
        paletteIcon?.classList.toggle("hidden", !colorsEnabled);
        yinYangIcon?.classList.toggle("hidden", colorsEnabled);
      }
    };

    const unsubscribe = store.subscribe(render);
    syncThemeVisibility();

    const onInput = (event) => {
      const target = event.target;

      if (!(target instanceof HTMLInputElement) || !target.dataset.path) {
        return;
      }

      const nextValue = target.type === "checkbox" ? target.checked : Number(target.value);
      store.update(target.dataset.path, nextValue);
    };

    const onPanelClick = (event) => {
      const button = event.target.closest("[data-action]");

      if (!(button instanceof HTMLButtonElement)) {
        return;
      }

      const action = button.dataset.action;

      if (action === "collapse") {
        setCollapsed(true);
      }

      if (action === "replay") {
        window.__homeAnimationAnimate?.replay?.();
      }

      if (action === "reset") {
        store.reset();
        window.__homeAnimationAnimate?.replay?.();
      }

      if (action === "toggle-theme") {
        window.changeTheme?.();
      }

      if (action === "toggle-colors") {
        const config = store.getConfig();
        const nextValue = !(config.twinkle.randomColors && config.meteor.randomColors);
        store.update("twinkle.randomColors", nextValue);
        store.update("meteor.randomColors", nextValue);
      }

      if (action === "toggle-enabled") {
        const path = button.dataset.enabledTogglePath;

        if (path) {
          const currentValue = Boolean(readHomeAnimationPath(store.getConfig(), path));
          store.update(path, !currentValue);
        }
      }
    };

    const onOpenClick = () => setCollapsed(false);
    const onSummaryClick = (event) => {
      if (event.target.closest("[data-summary-control]")) {
        event.preventDefault();
      }
    };
    const onToggle = (event) => {
      const detail = event.target;

      if (!(detail instanceof HTMLDetailsElement)) {
        return;
      }

      detail.dataset.manualState = detail.open ? "open" : "closed";
    };
    const themeObserver = new MutationObserver(() => syncThemeVisibility());

    panel.addEventListener("input", onInput);
    panel.addEventListener("click", onPanelClick);
    panel.addEventListener("click", onSummaryClick, true);
    openButton.addEventListener("click", onOpenClick);
    detailsSections.forEach((detail) => detail.addEventListener("toggle", onToggle));
    themeObserver.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["class"],
    });

    try {
      const savedState = window.localStorage.getItem(HOME_ANIMATION_PANEL_STORAGE_KEY);
      setCollapsed(savedState === null ? true : savedState === "1");
    } catch {
      setCollapsed(true);
    }

    return () => {
      unsubscribe?.();
      panel.removeEventListener("input", onInput);
      panel.removeEventListener("click", onPanelClick);
      panel.removeEventListener("click", onSummaryClick, true);
      openButton.removeEventListener("click", onOpenClick);
      detailsSections.forEach((detail) => detail.removeEventListener("toggle", onToggle));
      themeObserver.disconnect();
    };
  }

  window.__homeAnimationPanelCleanup?.();
  window.__homeAnimationPanelCleanup = mountHomeAnimationPanel();
</script>
