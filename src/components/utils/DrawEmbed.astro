<div class="space-y-3">
  <div class="flex flex-wrap items-center gap-2">
    <a
      href="https://excalidraw.com/"
      target="_blank"
      rel="noopener noreferrer"
      class="px-3 py-1 rounded-full text-sm border border-black/15 dark:border-white/25 hover:bg-black/5 hover:dark:bg-white/10 transition-colors duration-300 ease-in-out"
    >
      Open in new tab
    </a>
    <button
      id="draw-reload"
      type="button"
      class="px-3 py-1 rounded-full text-sm border border-black/15 dark:border-white/25 hover:bg-black/5 hover:dark:bg-white/10 transition-colors duration-300 ease-in-out"
    >
      Reload canvas
    </button>
    <div class="text-xs text-black/60 dark:text-white/60">
      Excalidraw stores your session in browser storage.
    </div>
  </div>

  <div class="border rounded-lg border-black/15 dark:border-white/20 overflow-hidden">
    <iframe
      id="draw-iframe"
      src="https://excalidraw.com/"
      title="Excalidraw"
      loading="lazy"
      class="w-full min-h-[70vh] bg-white"
    ></iframe>
  </div>
</div>

<script is:inline>
  const reloadButton = document.getElementById("draw-reload")
  const drawFrame = document.getElementById("draw-iframe")

  reloadButton?.addEventListener("click", () => {
    if (drawFrame instanceof HTMLIFrameElement) {
      drawFrame.src = drawFrame.src
    }
  })
</script>
